@article{looneyOutTropicsGlobal2016,
  title = {Into and out of the Tropics: Global Diversification Patterns in a Hyperdiverse Clade of Ectomycorrhizal Fungi},
  shorttitle = {Into and out of the Tropics},
  author = {Looney, Brian P. and Ryberg, Martin and Hampe, Felix and {S{\'a}nchez-Garc{\'i}a}, Marisol and Matheny, P. Brandon},
  year = 2016,
  journal = {Molecular Ecology},
  volume = {25},
  number = {2},
  pages = {630--647},
  issn = {1365-294X},
  doi = {10.1111/mec.13506},
  urldate = {2025-06-04},
  abstract = {Ectomycorrhizal (ECM) fungi, symbiotic mutualists of many dominant tree and shrub species, exhibit a biogeographic pattern counter to the established latitudinal diversity gradient of most macroflora and fauna. However, an evolutionary basis for this pattern has not been explicitly tested in a diverse lineage. In this study, we reconstructed a mega-phylogeny of a cosmopolitan and hyperdiverse genus of ECM fungi, Russula, sampling from annotated collections and utilizing publically available sequences deposited in GenBank. Metadata from molecular operational taxonomic unit cluster sets were examined to infer the distribution and plant association of the genus. This allowed us to test for differences in patterns of diversification between tropical and extratropical taxa, as well as how their associations with different plant lineages may be a driver of diversification. Results show that Russula is most species-rich at temperate latitudes and ancestral state reconstruction shows that the genus initially diversified in temperate areas. Migration into and out of the tropics characterizes the early evolution of the genus, and these transitions have been frequent since this time. We propose the `generalized diversification rate' hypothesis to explain the reversed latitudinal diversity gradient pattern in Russula as we detect a higher net diversification rate in extratropical lineages. Patterns of diversification with plant associates support host switching and host expansion as driving diversification, with a higher diversification rate in lineages associated with Pinaceae and frequent transitions to association with angiosperms.},
  copyright = {\copyright{} 2015 John Wiley \& Sons Ltd},
  langid = {english},
  keywords = {/unread,fungi,latitudinal diversity gradient,phylogeography,phyloinformatics,Russulaceae},
  annotation = {117 citations (Crossref) [2025-06-05]},
  file = {/Users/jpither/Zotero/storage/YEVIFP9T/mec.html}
}

@article{lumbierresAreaHabitatMaps2022,
  title = {Area of {{Habitat}} Maps for the World's Terrestrial Birds and Mammals},
  author = {Lumbierres, Maria and Dahal, Prabhat Raj and Soria, Carmen D. and Di Marco, Moreno and Butchart, Stuart H. M. and Donald, Paul F. and Rondinini, Carlo},
  year = 2022,
  month = dec,
  journal = {Scientific Data},
  volume = {9},
  number = {1},
  pages = {749},
  issn = {2052-4463},
  doi = {10.1038/s41597-022-01838-w},
  urldate = {2025-06-04},
  abstract = {Abstract             Area of Habitat (AOH) is ``the habitat available to a species, that is, habitat within its range''. It complements a geographic range map for a species by showing potential occupancy and reducing commission errors. AOH maps are produced by subtracting areas considered unsuitable for the species from their range map, using information on each species' associations with habitat and elevation. We present AOH maps for 5,481 terrestrial mammal and 10,651 terrestrial bird species (including 1,816 migratory bird species for which we present separate maps for the resident, breeding and non-breeding areas). Our maps have a resolution of 100\,m. On average, AOH covered 66\,\textpm\,28\% of the range maps for mammals and 64\,\textpm\,27\% for birds. The AOH maps were validated independently, following a novel two-step methodology: a modelling approach to identify outliers and a species-level approach based on point localities. We used AOH maps to produce global maps of the species richness of mammals, birds, globally threatened mammals and globally threatened birds.},
  langid = {english},
  keywords = {/unread},
  annotation = {33 citations (Crossref) [2025-06-04]},
  file = {/Users/jpither/Zotero/storage/YST999G6/Lumbierres et al. - 2022 - Area of Habitat maps for the world’s terrestrial b.pdf}
}

