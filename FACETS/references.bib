@misc{hebertBlitzGapNationwide2026,
  title = {Blitz the {{Gap}}: A Nation-Wide Effort to Guide Citizen Science toward the Needs of Biodiversity Science},
  shorttitle = {Blitz the {{Gap}}},
  author = {H{\'e}bert, Katherine and Earley, Nathan and Reynolds, John and Srivastava, Diane and Starzomski, Brian and Tseng, Michelle and Larocque, Guillaume and Pag{\'e}, James and {Raudsepp-Hearne}, Ciara and Soroye, Peter and Emry, Sandra and Hunt, David and Rogy, Pierre and Brabant, Christophe and {Deedes-Vincke}, Stephen and {Diaz-Corzo}, M. Camila and Eckert, Lukas and Kester, Nicole J. and Lee, Joshua and {Olu-Ayorinde}, Eniola and Trottier, Lindsay and Van Riel, Lukas and Yunusov, Sarfaroz and Eckert, Isaac and Serrano, Jana{\'i}na and Wightman, Noah and Horikawa, Maho and Hull, Ryan and Nagpal, Leeya and Drapeau Picard, Andr{\'e}-Philipp and {Lacroix-Carignan}, {\'E}tienne and Duplessis, Derek and {L{\'e}veill{\'e}-Bourret}, {\'E}tienne and Poulin, Marc-Antoine and Zerafa, Anthony and Pollock, Laura},
  year = 2026,
  publisher = {Biodiversity},
  doi = {10.32942/X2T09G},
  urldate = {2026-06-29},
  abstract = {To resolve persistent biases in conservation assessments and forecasting, we urgently need more systematic collection of biodiversity data. Citizen (or, community) science, despite its reputation for unstructured data, offers a particularly promising path forward, mobilizing participation at scales and speeds unmatched by traditional monitoring. Here, we introduce Blitz the Gap, a pan-Canadian initiative to guide citizen science with sampling `challenges', bioblitzes and paid initiatives using iNaturalist. One year of semi-guided sampling helped to gain 540 species newly recorded on iNaturalist Canada, almost 50,000 km2 of added spatial coverage, better representation of northern climates, and new evidence to help identify Key Biodiversity Areas. These results demonstrate the potential for guided citizen science, especially for taxonomic discovery, range-filling, and early alerts for species on the move. Our experience highlights the need for more tailored guidance and gamification, further development of adaptive sampling methods, and funding for bioblitzes and training of future taxonomists and naturalists. As countries work towards global conservation targets for 2030 and 2050, citizen science should be one of the core pillars of any large-scale monitoring network, contributing unparalleled taxonomic depth and engagement.},
  archiveprefix = {Biodiversity}
}

