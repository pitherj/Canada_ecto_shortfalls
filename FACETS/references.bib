@article{qinHighResolutionRangeMapping2026,
  title = {High-{{Resolution Range Mapping}} of {{Mycorrhizal Fungal Species Reveals Systematic Biases}} in {{Their Protection}}},
  author = {Qin, Clara and Kumar, Sujai and Elhance, Jinsu and Manley, Bethan F. and Corrales, Adriana and Polyakov, Anne and Stewart, Justin D. and Kivlin, Stephanie and Odriozola, I{\~n}aki and V{\v e}trovsk{\'y}, Tom{\'a}{\v s} and Kohout, Petr and Baldrian, Petr and Kiers, E. Toby and Van Nuland, Michael E.},
  year = 2026,
  month = may,
  journal = {Conservation Letters},
  volume = {19},
  number = {3},
  pages = {e70051},
  issn = {1755-263X, 1755-263X},
  doi = {10.1111/con4.70051},
  urldate = {2026-05-29},
  abstract = {ABSTRACT Mycorrhizal fungi are essential to ecosystem functioning but have been overlooked in conservation agendas due to data limitations and a historical focus on plants and animals. We present the first global, species-level assessment of the area-based conservation of mycorrhizal fungi. Using 16.5 million site-by-taxon presence--absence records, we created kilometer-scale range maps for 189 arbuscular mycorrhizal and 2669 ectomycorrhizal species hypotheses. By intersecting these range maps with protected areas, we show that arbuscular mycorrhizal fungi are less protected than expected by random chance, and both guilds are less protected than terrestrial mammals. The Species Protection Index (SPI) measures the protection of species ranges, but it is sensitive to estimated range size. Nonetheless, the SPI framework can be used with our maps to monitor and inform mycorrhizal fungal habitat protection. Our findings highlight the value of species-level spatial data in fungal conservation planning to mitigate extinction risks associated with habitat loss.},
  langid = {english}
}

